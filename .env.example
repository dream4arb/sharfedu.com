# Database Configuration
# For local development, leave DATABASE_URL empty to use sqlite.db in project root
# Or specify a custom path: DATABASE_URL=./data/my-database.db
# Note: The file: protocol will be added automatically
DATABASE_URL=

# Session Secret
# Generate a random secret for production: openssl rand -base64 32
SESSION_SECRET=change-this-secret-key-in-production

# Node Environment
NODE_ENV=development

# Google Gemini API Key (required for AI features)
# Get your API key from: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# YouTube Data API v3 — مدة الفيديو، عدد المشاهدات، عنوان القناة (إن تركت فارغاً لن تظهر بيانات الفيديو)
# احصل على المفتاح من: Google Cloud Console → APIs & Services → Enable "YouTube Data API v3" → Create credentials → API key
# YOUTUBE_API_KEY=your-youtube-api-key

# Server Port (optional, defaults to 5000)
# PORT=5000

# Admin: البريد الإلكتروني للمدير الأول (يُمنح صلاحية admin)
# ADMIN_EMAIL=admin@example.com

# Google OAuth (اختياري - لخيار الدخول عبر جوجل)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
